;; ---------------------------------------------------------------------------
;; misc

(t/defaction roam-select-block-hat
  "select block hat"
  [target :- python/str]
  (insert! target)
  (sleep! "300ms"))

(t/defaction roam-insert-snippet
  "inster a talon snippet with a text substitution"
  [snippet-name :- python/str
   text :- python/str]
  (.insert_snippet_by_name user-a snippet-name (python/dict {"0" text}))
  (sleep! "100ms"))

(t/defaction roam-wrap-snippet
  "inster a talon snippet with a text substitution"
  [snippet-name :- python/str
   text :- python/str]
  (.insert_snippet_by_name user-a snippet-name (python/dict {"0" text}))
  (sleep! "100ms"))

(t/defaction roam-open-command-palette
  "exit block edit, then block selected mode"
  []
  (key! "cmd-p"))

(t/defaction roam-teleport-todo-date-tag
  "exit block edit, then block selected mode"
  []
  (key! "cmd-shift-t"))

(t/defaction roam-teleport-todo-block
  "exit block edit, then block selected mode"
  []
  (key! "cmd-shift-t"))

(t/defaction roam-copy-block-ref
  "exit block edit, then block selected mode"
  []
  (key! "cmd-shift-e"))

(t/defaction roam-open-switch-page-search
  "switch + plugin modal navigate blocks, references, and sidebar currently on page"
  []
  (key! "cmd-shift-p"))

(t/defaction roam-basil-test
  "live-loop smoke test: edit the println, save, speak, watch the log"
  []
  (println "hello from basillisp clojure in roam xxx!"))

;; ---------------------------------------------------------------------------

(t/register! "user.ryan.roam.roam" "Roam Research actions (pure Basilisp)")

(println "ryan.roam.roam: actions registered")
