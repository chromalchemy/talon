  (roam-start-send-block-to-reference-top-leave-reference)
  (insert! reference)
  (roam-close-out-send-block-modal-from-ref-field))

(t/defaction roam-start-send-block-to-page-top-and-leave-reference
  "start send block to page"
  []
  (roam-start-send-block-to-location-top-leave-reference)
  (roam-select-send-block-to-page-field))

(t/defaction roam-send-block-to-page-top-and-leave-reference
  "send block to page and leave ref"
