app.name: Roam Research 
mode: command
-

## +++++++++++++++ markdown formatting .

bold that: key(cmd-b)

## ++++++++++++++++++++++++++ headings .

[make] (heading | header) one: 
    key(cmd-alt-1)

[make] (heading | header) two: 
    key(cmd-alt-2)

[make] (heading | header) three: 
    key(cmd-alt-3)

[make] (heading | header) none | remove (heading | header (format | formatting)): 
    key(cmd-alt-0)